    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
