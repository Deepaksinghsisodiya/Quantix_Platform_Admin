    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "formik": "^2.4.9",
    "lucide-react": "^1.11.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.6.0",
    "react-is": "^19.2.4",
    "react-redux": "^9.2.0",
